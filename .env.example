RESEND_FROM_EMAIL=noreply@frame.app

# ── NextAuth / Session ─────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
LUMEN_EDITOR_EMAILS=
LUMEN_EDITOR_USERNAMES=
LUMEN_DEFAULT_LOGIN_USERNAME=Lumen
LUMEN_DEFAULT_IMPORT_CREATOR_USERNAME=Lumen
LUMEN_DEFAULT_IMPORT_CREATOR_BIO=由 Lumen 手动导入与整理的壁纸作者。
CRON_SECRET=
